{
  "name": "market_cap_growth",
  "description": "市值增长策略：今日流通市值 - 昨日流通市值，从大到小排列",
  "table": "strategy_market_cap_growth",
  "columns": [
    {
      "name": "code",
      "type": "VARCHAR",
      "not_null": true
    },
    {
      "name": "code_name",
      "type": "VARCHAR"
    },
    {
      "name": "date",
      "type": "DATE",
      "not_null": true
    },
    {
      "name": "flow_cap",
      "type": "DOUBLE"
    },
    {
      "name": "cap_change",
      "type": "DOUBLE"
    },
    {
      "name": "rank",
      "type": "INTEGER"
    }
  ],
  "primary_key": [
    "code",
    "date"
  ],
  "compute": {
    "type": "python",
    "function": "market_cap_growth"
  },
  "write_sql": "DELETE FROM strategy_market_cap_growth WHERE date = ?; INSERT INTO strategy_market_cap_growth SELECT * FROM df",
  "read_sql": "SELECT * FROM strategy_market_cap_growth WHERE date = ? ORDER BY rank",
  "params": {},
  "last_date": "2026-04-28",
  "_说明": {
    "flow_cap": "今日流通市值（亿元）",
    "cap_change": "今日市值 - 昨日市值（亿元），正值=增长，负值=缩水",
    "rank": "按 cap_change 降序排名"
  }
}